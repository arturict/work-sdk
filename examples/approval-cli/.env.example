# Choose: memory, github, linear, jira, azure-devops
WORK_PROVIDER=memory
WORK_ITEM_ID=42
WORK_TARGET_STATE=completed

# GitHub Issues — fake values, replace only in your local .env
GITHUB_TOKEN=github_pat_example_not_a_real_token
GITHUB_OWNER=acme-example
GITHUB_REPO=platform-api

# Linear — fake values
LINEAR_API_KEY=lin_api_example_not_a_real_key
LINEAR_TEAM_ID=team_example_123

# Jira Cloud — fake values
JIRA_BASE_URL=https://acme-example.atlassian.net
JIRA_EMAIL=agent@example.com
JIRA_API_TOKEN=jira_example_not_a_real_token
JIRA_PROJECT_KEY=ENG

# Azure DevOps — fake values
AZURE_DEVOPS_ORGANIZATION=acme-example
AZURE_DEVOPS_PROJECT=Platform
AZURE_DEVOPS_AUTH=entra
AZURE_DEVOPS_TOKEN=azure_example_not_a_real_token
AZURE_DEVOPS_DEFAULT_TYPE=Task
